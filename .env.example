# Copy this file to .env and adjust as needed. All of these have sane
# defaults (see app/config.py) and are optional; the Plex token and
# notification channel credentials are entered via the /settings page after
# first boot, not here, since they're secrets best kept out of shell history.

# Where the SQLite database file lives.
ENTRACTE_DB_PATH=./data/entracte.db

# Address/port uvicorn binds to when run directly (not via Docker, where
# these are fixed in the Dockerfile's CMD).
ENTRACTE_HOST=0.0.0.0
ENTRACTE_PORT=8000

# Pre-fills the Plex server URL field on /settings on first run.
ENTRACTE_PLEX_BASE_URL_DEFAULT=http://localhost:32400

# How often (seconds) the polling fallback checks Plex when the websocket
# notification feed is unavailable.
ENTRACTE_POLL_INTERVAL_S=7.0
